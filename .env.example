# Admin panel credentials (required for /admin to work)
ADMIN_USERNAME=your_username
ADMIN_PASSWORD=your_strong_password
ADMIN_TOKEN_SECRET=any_random_string_here

# Site URL (used for canonical URLs, sitemap, OG tags, and image URLs in production)
# Set this on your VPS before building so blog images load correctly.
# NEXT_PUBLIC_SITE_URL=https://mernet.co.tz
